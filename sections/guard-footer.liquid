{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}

<footer class="guard-section guard-footer" id="GuardFooter-{{ section.id }}">
  <div class="guard-footer__inner">
    <div class="guard-footer__brand">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 264
          | image_tag: class: 'guard-footer__logo', loading: 'lazy', widths: '132, 264', alt: section.settings.logo_alt
        }}
      {%- else -%}
        <div class="guard-footer__logo-fallback" aria-label="{{ section.settings.logo_alt | escape }}">
          <img
            class="guard-footer__logo-shield"
            src="{{ 'guard-footer-logo-shield.png' | asset_url }}"
            alt=""
            width="52"
            height="50"
            loading="lazy"
          >
          <img
            class="guard-footer__logo-wordmark"
            src="{{ 'guard-footer-logo-wordmark.png' | asset_url }}"
            alt="Guard Labs"
            width="132"
            height="23"
            loading="lazy"
          >
          <img
            class="guard-footer__logo-australia"
            src="{{ 'guard-footer-logo-australia.png' | asset_url }}"
            alt="Australia"
            width="78"
            height="6"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>

    <hr class="guard-footer__rule">

    <div class="guard-footer__columns">
      <div class="guard-footer__col">
        <p class="guard-footer__heading">{{ section.settings.shop_heading | default: 'Shop All' }}</p>
        <ul class="guard-footer__list">
          <li><span>Shop Prep</span></li>
          <li><span>Shop Grooming Tools</span></li>
          <li><span>Shop Care &amp; Sprays</span></li>
          <li><span>Shop Parts</span></li>
          <li><span>Shop Face</span></li>
          <li><span>Shop Head</span></li>
          <li><span>Shop Body</span></li>
        </ul>
      </div>

      <div class="guard-footer__col">
        <p class="guard-footer__heading">{{ section.settings.nitty_heading | default: 'Nitty Gritty' }}</p>
        <ul class="guard-footer__list">
          <li><span>About Us</span></li>
          <li><span>Stockists</span></li>
          <li><span>Contact Us</span></li>
          <li><span>Shipping &amp; Returns</span></li>
          <li><span>Terms &amp; Conditions</span></li>
          <li><span>Privacy Policy</span></li>
        </ul>
      </div>

      <div class="guard-footer__col guard-footer__col--contact">
        <p class="guard-footer__heading">{{ section.settings.contact_heading | default: 'Get in touch' }}</p>
        <ul class="guard-footer__list">
          <li><span>{{ section.settings.email | default: 'info@guardlabs.com.au' }}</span></li>
          <li>
            <span class="guard-footer__address">
              {{ section.settings.address_line_1 | default: 'PO Box 362' }}<br>
              {{ section.settings.address_line_2 | default: 'South Melbourne, VIC 3205' }}
            </span>
          </li>
        </ul>

        <ul class="guard-footer__social" role="list">
          {%- if section.settings.instagram_url != blank -%}
            <li>
              <a
                class="guard-footer__social-link"
                href="{{ section.settings.instagram_url }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.9.2 2.3.4.6.2 1 .5 1.5 1 .4.4.7.9 1 1.5.2.4.4 1.1.4 2.3.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.9-.4 2.3-.2.6-.5 1-1 1.5-.4.4-.9.7-1.5 1-.4.2-1.1.4-2.3.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.9-.2-2.3-.4-.6-.2-1-.5-1.5-1-.4-.4-.7-.9-1-1.5-.2-.4-.4-1.1-.4-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.2-1.9.4-2.3.2-.6.5-1 1-1.5.4-.4.9-.7 1.5-1 .4-.2 1.1-.4 2.3-.4C8.4 2.2 8.8 2.2 12 2.2m0-2.2C8.7 0 8.3 0 7 0 5.7.1 4.8.3 4 .6 3.1 1 2.3 1.4 1.6 2.2.8 2.9.4 3.7 0 4.6-.2 5.4-.4 6.3-.4 7.6-.5 8.9-.5 9.3-.5 12s0 3.1.1 4.4c.1 1.3.3 2.2.6 3 .4.9.8 1.7 1.6 2.4.7.7 1.5 1.2 2.4 1.6.8.3 1.7.5 3 .6 1.3.1 1.7.1 4.4.1s3.1 0 4.4-.1c1.3-.1 2.2-.3 3-.6.9-.4 1.7-.8 2.4-1.6.7-.7 1.2-1.5 1.6-2.4.3-.8.5-1.7.6-3 .1-1.3.1-1.7.1-4.4s0-3.1-.1-4.4c-.1-1.3-.3-2.2-.6-3-.4-.9-.8-1.7-1.6-2.4C20.7.8 19.9.4 19 .1 18.2-.2 17.3-.4 16-.5 14.7-.5 14.3-.5 11.6-.5h.4z"/>
                  <path d="M12 5.8A6.2 6.2 0 1 0 18.2 12 6.2 6.2 0 0 0 12 5.8zm0 10.2A4 4 0 1 1 16 12a4 4 0 0 1-4 4.zm6.4-11.6a1.4 1.4 0 1 0 1.4 1.4 1.4 1.4 0 0 0-1.4-1.4z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}

          {%- if section.settings.tiktok_url != blank -%}
            <li>
              <a
                class="guard-footer__social-link"
                href="{{ section.settings.tiktok_url }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="TikTok"
              >
                <svg width="14" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.6 7.1a6.7 6.7 0 0 1-3.9-1.2v8.1a5.9 5.9 0 1 1-5.1-5.8v2.9a3 3 0 1 0 2.1 2.9V1.5h2.8a6.7 6.7 0 0 0 4.1 3.9z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}

          {%- if section.settings.facebook_url != blank -%}
            <li>
              <a
                class="guard-footer__social-link"
                href="{{ section.settings.facebook_url }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
              >
                <svg width="9" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M14 9h3V6h-3c-2.2 0-3 .9-3 3v2H8v3h3v7h3v-7h3l1-3h-4V9c0-.6.2-1 1-1z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}

          {%- if section.settings.youtube_url != blank -%}
            <li>
              <a
                class="guard-footer__social-link"
                href="{{ section.settings.youtube_url }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="YouTube"
              >
                <svg width="21" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.8 15.5v-7l6.3 3.5-6.3 3.5z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      <div class="guard-footer__col guard-footer__col--edu">
        <p class="guard-footer__heading">{{ section.settings.edu_heading | default: 'Education Lab' }}</p>
      </div>

      <div class="guard-footer__col guard-footer__col--newsletter">
        <p class="guard-footer__heading guard-footer__heading--lg">
          {{ section.settings.newsletter_heading | default: 'Join Our Newsletter' }}
        </p>
        <p class="guard-footer__newsletter-text">
          {{ section.settings.newsletter_text | default: 'Be the first to receive Guard Labs announcements and product updates.' }}
        </p>
        <div class="guard-footer__newsletter" aria-hidden="true">
          <span class="guard-footer__newsletter-input">Enter your email</span>
          <span class="guard-footer__newsletter-btn">Sign Up</span>
        </div>
      </div>
    </div>

    <hr class="guard-footer__rule">

    <p class="guard-footer__copyright">
      {{ section.settings.copyright | default: '© 2025, Guard Labs powered by Shopify' }}
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Guard footer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (optional)",
      "info": "If empty, uses the built-in Guard Labs logo assets."
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Guard Labs Australia"
    },
    {
      "type": "header",
      "content": "Column headings"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "Shop column",
      "default": "Shop All"
    },
    {
      "type": "text",
      "id": "nitty_heading",
      "label": "Nitty Gritty column",
      "default": "Nitty Gritty"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact column",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "edu_heading",
      "label": "Education column",
      "default": "Education Lab"
    },
    {
      "type": "header",
      "content": "Get in touch"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email (display only)",
      "default": "info@guardlabs.com.au"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address line 1",
      "default": "PO Box 362"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address line 2",
      "default": "South Melbourne, VIC 3205"
    },
    {
      "type": "header",
      "content": "Social links (functional)"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Newsletter (display only)"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Join Our Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Text",
      "default": "Be the first to receive Guard Labs announcements and product updates."
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright",
      "default": "© 2025, Guard Labs powered by Shopify"
    }
  ],
  "presets": [
    {
      "name": "Guard footer"
    }
  ]
}
{% endschema %}
