{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'guard-video-autoplay.js' | asset_url }}" defer="defer"></script>

<section class="guard-section guard-ugc" id="GuardUgc-{{ section.id }}">
  <h2 class="guard-ugc__heading">{{ section.settings.heading | default: 'Your grooming, your way.' }}</h2>
  <p class="guard-ugc__sub">{{ section.settings.subheading | default: 'Real routines, real results.' }}</p>

  <div class="guard-ugc__track">
    {%- for block in section.blocks -%}
      {%- liquid
        assign has_video = false
        if block.settings.video != blank
          assign has_video = true
        endif

        assign has_video_url = false
        if block.settings.video_url != blank
          assign has_video_url = true
        endif

        assign has_image = false
        if block.settings.image != blank
          assign has_image = true
        endif

        assign should_autoplay = block.settings.autoplay
      -%}

      <div class="guard-ugc__item" {{ block.shopify_attributes }}>
        <div class="guard-ugc__media">
          {%- if has_video -%}
            <video
              class="guard-ugc__video"
              data-guard-video
              {% if should_autoplay %}
                autoplay
                data-autoplay="true"
              {% endif %}
              loop
              muted
              playsinline
              webkit-playsinline
              preload="auto"
              {% if should_autoplay == false and block.settings.show_controls %}controls{% endif %}
              {% if block.settings.show_controls %}controls{% endif %}
              {% if has_image %}
                poster="{{ block.settings.image | image_url: width: 600 }}"
              {% elsif block.settings.video.preview_image != blank %}
                poster="{{ block.settings.video.preview_image | image_url: width: 600 }}"
              {% endif %}
            >
              {%- for source in block.settings.video.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif has_video_url -%}
            <video
              class="guard-ugc__video"
              data-guard-video
              {% if should_autoplay %}
                autoplay
                data-autoplay="true"
              {% endif %}
              loop
              muted
              playsinline
              webkit-playsinline
              preload="auto"
              {% if block.settings.show_controls %}controls{% endif %}
              {% if has_image %}
                poster="{{ block.settings.image | image_url: width: 600 }}"
              {% endif %}
            >
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {%- elsif has_image -%}
            {{
              block.settings.image
              | image_url: width: 600
              | image_tag: loading: 'lazy', widths: '300, 450, 600', sizes: '240px', class: 'guard-ugc__image'
            }}
          {%- else -%}
            <div class="guard-placeholder" role="img" aria-label="UGC video {{ forloop.index }}"></div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- liquid
    assign ugc_product = blank
    assign ugc_show_product = false
    for block in section.blocks
      if block.settings.show_product_card and ugc_show_product == false
        assign ugc_product = block.settings.product
        assign ugc_show_product = true
      endif
    endfor
  -%}

  {%- if ugc_show_product -%}
    <div class="guard-ugc__product-row">
      <div class="guard-ugc__product">
        <div class="guard-ugc__product-thumb">
          {%- if ugc_product != blank and ugc_product.featured_media -%}
            {{ ugc_product.featured_media | image_url: width: 80 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </div>
        <div class="guard-ugc__product-info">
          <p class="guard-ugc__product-name">
            {%- if ugc_product != blank -%}
              {{ ugc_product.title }}
            {%- else -%}
              PRODUCT NAME
            {%- endif -%}
          </p>
          <p class="guard-ugc__product-price">
            {%- if ugc_product != blank -%}
              {{ ugc_product.price | money }}
            {%- else -%}
              $X
            {%- endif -%}
          </p>
        </div>
        <a
          class="guard-card__arrow"
          href="{% if ugc_product != blank %}{{ ugc_product.url }}{% else %}#{% endif %}"
          aria-label="View product"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  {%- endif -%}

  <div class="guard-ugc__dots" aria-hidden="true">
    {%- for block in section.blocks -%}
      <span{% if forloop.first %} class="is-active"{% endif %}></span>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Guard UGC videos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your grooming, your way."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real routines, real results."
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video / image card",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "External MP4 URL",
          "info": "Must be a direct .mp4 link (Dropbox share links usually fail — use a CDN or Shopify-hosted video)."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Poster / fallback image",
          "info": "Used as poster for video, or as the card media when no video is set"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay (muted)",
          "default": true,
          "info": "Browsers only allow autoplay when the video is muted. Low Power Mode on iOS can still block it."
        },
        {
          "type": "checkbox",
          "id": "show_controls",
          "label": "Show video controls",
          "default": false
        },
        {
          "type": "header",
          "content": "Product card (below videos)"
        },
        {
          "type": "checkbox",
          "id": "show_product_card",
          "label": "Show product card under videos",
          "default": false,
          "info": "Only the first enabled card is shown, centered below the video row."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Guard UGC videos",
      "blocks": [
        { "type": "video_card", "settings": { "show_product_card": true, "autoplay": true } },
        { "type": "video_card", "settings": { "autoplay": true } },
        { "type": "video_card", "settings": { "autoplay": true } },
        { "type": "video_card", "settings": { "autoplay": true } },
        { "type": "video_card", "settings": { "autoplay": true } }
      ]
    }
  ]
}
{% endschema %}
