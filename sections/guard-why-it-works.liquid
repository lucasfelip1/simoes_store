{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}

<section class="guard-section guard-checker" id="GuardWhy-{{ section.id }}">
  <div class="guard-checker__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1400
        | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1400', sizes: '(min-width: 750px) 50vw, 100vw'
      }}
    {%- else -%}
      <div class="guard-placeholder" style="height:100%;min-height:32rem;" role="img" aria-label="Why It Works"></div>
    {%- endif -%}
  </div>
  <div class="guard-checker__content">
    <h2 class="guard-section__heading">{{ section.settings.heading | default: 'Why It Works' }}</h2>
    <div class="guard-checker__text rte">
      {%- if section.settings.text != blank -%}
        {{ section.settings.text }}
      {%- elsif product.metafields.custom.why_it_works != blank -%}
        {{ product.metafields.custom.why_it_works | metafield_tag }}
      {%- else -%}
        <p>
          Our <strong>Ultra Close Tech™</strong> blades are designed to cut closer while reducing tug and pull —
          meaning smoother skin, fewer bumps. The <strong>pivoting head</strong> adjusts to your face shape, and
          the Guard Labs <strong>shaving oil</strong> preps your skin so every glide feels effortless.
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guard Why It Works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why It Works"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Our <strong>Ultra Close Tech™</strong> blades are designed to cut closer while reducing tug and pull — meaning smoother skin, fewer bumps. The <strong>pivoting head</strong> adjusts to your face shape, and the Guard Labs <strong>shaving oil</strong> preps your skin so every glide feels effortless.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Guard Why It Works"
    }
  ]
}
{% endschema %}
