{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}

<section class="guard-section guard-complete" id="GuardComplete-{{ section.id }}">
  <h2 class="guard-section__heading">{{ section.settings.heading | default: 'Complete the Set' }}</h2>
  <div class="guard-complete__grid">
    {%- if section.settings.collection != blank -%}
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        <article class="guard-card">
          <div class="guard-card__media">
            {%- if forloop.first and section.settings.show_badge -%}
              <span class="guard-badge guard-card__badge">BEST SELLER</span>
            {%- endif -%}
            {%- if product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 800
                | image_tag: loading: 'lazy', widths: '300, 500, 800', sizes: '(min-width: 750px) 30vw, 90vw'
              }}
            {%- else -%}
              <div class="guard-placeholder" style="height:100%;"></div>
            {%- endif -%}
          </div>
          <h3 class="guard-card__title">{{ product.title }}</h3>
          <p class="guard-card__category">{{ product.type | default: product.vendor }}</p>
          <div class="guard-card__footer">
            <div class="guard-card__price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <s>{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
            <a class="guard-card__arrow" href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..3) -%}
        <article class="guard-card">
          <div class="guard-card__media">
            {%- if i == 1 -%}
              <span class="guard-badge guard-card__badge">BEST SELLER</span>
            {%- endif -%}
            <div class="guard-placeholder" style="height:100%;"></div>
          </div>
          <h3 class="guard-card__title">PRODUCT NAME</h3>
          <p class="guard-card__category">CATEGORY NAME</p>
          <div class="guard-card__footer">
            <div class="guard-card__price">$189.95 <s>$199.95</s></div>
            <a class="guard-card__arrow" href="#" aria-label="View product">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Guard Complete the Set",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete the Set"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products to show",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show best seller on first card",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Guard Complete the Set"
    }
  ]
}
{% endschema %}
