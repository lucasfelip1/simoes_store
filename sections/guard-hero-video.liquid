{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'guard-video-autoplay.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign has_shopify_video = false
  if section.settings.video != blank
    assign has_shopify_video = true
  endif

  assign has_external_video = false
  if section.settings.video_url != blank
    assign has_external_video = true
  endif

  assign has_poster = false
  if section.settings.poster != blank
    assign has_poster = true
  endif

  assign should_autoplay = section.settings.autoplay
-%}

<section
  class="guard-section guard-hero-video"
  id="GuardHeroVideo-{{ section.id }}"
  data-frame="427318198"
>
  <div class="guard-hero-video__frame">
    {%- if has_shopify_video -%}
      <video
        class="guard-hero-video__media"
        data-guard-video
        {% if should_autoplay %}
          autoplay
          data-autoplay="true"
        {% endif %}
        {% if section.settings.loop %}loop{% endif %}
        muted
        playsinline
        webkit-playsinline
        preload="auto"
        {% if section.settings.show_controls %}controls{% endif %}
        {% if has_poster %}
          poster="{{ section.settings.poster | image_url: width: 1920 }}"
        {% elsif section.settings.video.preview_image != blank %}
          poster="{{ section.settings.video.preview_image | image_url: width: 1920 }}"
        {% endif %}
      >
        {%- for source in section.settings.video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    {%- elsif has_external_video -%}
      <video
        class="guard-hero-video__media"
        data-guard-video
        {% if should_autoplay %}
          autoplay
          data-autoplay="true"
        {% endif %}
        {% if section.settings.loop %}loop{% endif %}
        muted
        playsinline
        webkit-playsinline
        preload="auto"
        {% if section.settings.show_controls %}controls{% endif %}
        {% if has_poster %}
          poster="{{ section.settings.poster | image_url: width: 1920 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif has_poster -%}
      {{
        section.settings.poster
        | image_url: width: 1920
        | image_tag:
          class: 'guard-hero-video__media',
          loading: 'lazy',
          widths: '750, 1100, 1500, 1920',
          sizes: '100vw',
          alt: section.settings.heading
      }}
    {%- else -%}
      <div
        class="guard-hero-video__media guard-placeholder"
        role="img"
        aria-label="{{ section.settings.heading | escape }}"
      ></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Guard product video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Frame 427318198 — above Shop"
    },
    {
      "type": "paragraph",
      "content": "Full-bleed video above Why It Works / How to Use. Annotation: Electricals have a video."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Accessibility label",
      "default": "Product video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "External MP4 URL",
      "info": "Must be a direct .mp4 link. Dropbox share pages usually fail — prefer Shopify-hosted video."
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster / fallback image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (muted)",
      "default": true,
      "info": "Browsers only allow autoplay when muted. iOS Low Power Mode can still block it."
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Guard product video"
    }
  ]
}
{% endschema %}
