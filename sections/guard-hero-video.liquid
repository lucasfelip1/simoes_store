{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_shopify_video = false
  if section.settings.video != blank
    assign has_shopify_video = true
  endif

  assign has_external_video = false
  if section.settings.video_url != blank
    assign has_external_video = true
  endif

  assign has_poster = false
  if section.settings.poster != blank
    assign has_poster = true
  endif
-%}

<section
  class="guard-section guard-hero-video"
  id="GuardHeroVideo-{{ section.id }}"
  data-frame="427318198"
>
  <div class="guard-hero-video__frame">
    {%- if has_shopify_video -%}
      {{
        section.settings.video
        | video_tag:
          image_size: '1920x',
          autoplay: section.settings.autoplay,
          loop: section.settings.loop,
          muted: true,
          controls: section.settings.show_controls,
          class: 'guard-hero-video__media'
      }}
    {%- elsif has_external_video -%}
      <video
        class="guard-hero-video__media"
        {% if section.settings.autoplay %}autoplay{% endif %}
        {% if section.settings.loop %}loop{% endif %}
        muted
        playsinline
        {% if section.settings.show_controls %}controls{% endif %}
        {% if has_poster %}
          poster="{{ section.settings.poster | image_url: width: 1920 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif has_poster -%}
      {{
        section.settings.poster
        | image_url: width: 1920
        | image_tag:
          class: 'guard-hero-video__media',
          loading: 'lazy',
          widths: '750, 1100, 1500, 1920',
          sizes: '100vw',
          alt: section.settings.heading
      }}
    {%- else -%}
      <div
        class="guard-hero-video__media guard-placeholder"
        role="img"
        aria-label="{{ section.settings.heading | escape }}"
      ></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Guard product video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Frame 427318198 — above Shop"
    },
    {
      "type": "paragraph",
      "content": "Full-bleed video above Why It Works / How to Use. Annotation: Electricals have a video."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Accessibility label",
      "default": "Product video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "External MP4 URL",
      "info": "Optional Dropbox/CDN .mp4 link if not using Shopify-hosted video"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster / fallback image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (muted)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Guard product video"
    }
  ]
}
{% endschema %}
