{{ 'guard-labs-pdp.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="guard-section guard-hero-video section-{{ section.id }}-padding" id="GuardHeroVideo-{{ section.id }}">
  {%- if section.settings.video != blank -%}
    {{
      section.settings.video
      | video_tag:
        image_size: '1920x',
        autoplay: section.settings.autoplay,
        loop: section.settings.loop,
        muted: true,
        controls: true,
        class: 'guard-hero-video__media'
    }}
  {%- elsif section.settings.video_url != blank -%}
    <video
      class="guard-hero-video__media"
      {% if section.settings.autoplay %}autoplay{% endif %}
      {% if section.settings.loop %}loop{% endif %}
      muted
      playsinline
      controls
      poster="{% if section.settings.poster != blank %}{{ section.settings.poster | image_url: width: 1920 }}{% endif %}"
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.poster != blank -%}
    {{
      section.settings.poster
      | image_url: width: 1920
      | image_tag: class: 'guard-hero-video__media', loading: 'lazy', widths: '750, 1100, 1500, 1920'
    }}
  {%- else -%}
    <div class="guard-hero-video__media guard-placeholder guard-placeholder--video" role="img" aria-label="{{ section.settings.heading | escape }}"></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Guard hero video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accessibility label",
      "default": "Product video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "External MP4 URL",
      "info": "Optional Dropbox/CDN mp4 link"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster / fallback image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Guard hero video"
    }
  ]
}
{% endschema %}
