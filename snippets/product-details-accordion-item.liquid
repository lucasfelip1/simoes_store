{% comment %}
  Renders one product details accordion row when metafield or fallback content exists.

  Accepts:
  - metafield: {Object} Product metafield
  - fallback_html: {String} Optional HTML/text fallback for sample pages
  - title: {String} Accordion heading
  - icon: {String} Icon name for icon-accordion snippet
  - section_id: {String} Section ID for unique element IDs
  - item_id: {String} Unique slug for this row
  - open: {Boolean} Whether details starts open
{% endcomment %}

{%- liquid
  assign content_html = blank
  if metafield != blank
    assign content_html = metafield | metafield_tag
  elsif fallback_html != blank
    assign content_html = fallback_html
  endif
-%}

{%- if content_html != blank -%}
  <div class="product-details-accordions__item accordion">
    <details
      id="Details-product-details-{{ item_id }}-{{ section_id }}"
      {% if open %}
        open
      {% endif %}
    >
      <summary>
        <div class="summary__title">
          {% render 'icon-accordion', icon: icon %}
          <h2 class="h4 accordion__title product-details-accordions__title">
            {{ title }}
          </h2>
        </div>
        {% render 'icon-caret' %}
      </summary>
      <div
        class="accordion__content rte product-details-accordions__content"
        id="ProductDetailsAccordion-{{ item_id }}-{{ section_id }}"
      >
        {{ content_html }}
      </div>
    </details>
  </div>
{%- endif -%}
